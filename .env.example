# Local prototype uses SQLite. Schema is provider="sqlite" so no Postgres needed.
DATABASE_URL="file:./dev.db"

# Auth.js
AUTH_SECRET="run: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# Supabase Realtime (optional — live feed falls back to polling without these)
NEXT_PUBLIC_SUPABASE_URL="https://example.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="anon"

# Cron protection (used in /api/cron/simulate-txn)
CRON_SECRET="run: openssl rand -base64 24"
